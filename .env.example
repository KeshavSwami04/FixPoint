# ── Backend ──────────────────────────────────────────────────────────────────
# Generate SECRET_KEY with: openssl rand -hex 32
SECRET_KEY=replace-with-a-random-32-byte-hex-string

# Generate CRON_SECRET with: openssl rand -hex 16
CRON_SECRET=replace-with-a-random-string

# Database (use Railway MySQL values in production)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=replace-with-strong-password
DB_NAME=instifix_db

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=http://localhost

# ── Frontend (Vite / Vercel) ──────────────────────────────────────────────────
# Set this to your Railway backend URL so the frontend knows where the API is.
# In Docker (local), leave blank — nginx proxies /api internally.
# On Vercel, set this as an environment variable in the Vercel dashboard.
VITE_API_URL=https://your-backend.railway.app
